HOMEPAGE_DOMAIN=khe.ee

# AdGuard Home credentials
ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=your-adguard-password

# Immich API key (Immich → Account Settings → API Keys → New API Key)
IMMICH_API_KEY=

# Jellyfin API key (Jellyfin → Dashboard → API Keys → +)
JELLYFIN_API_KEY=

# Audiobookshelf API token (ABS → Settings → Users → your user → API Token)
AUDIOBOOKSHELF_API_KEY=

# Paperless-ngx API token (Paperless → Settings → REST API)
PAPERLESS_API_KEY=

# Nextcloud admin credentials
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your-nextcloud-password

# n8n API key (n8n → Settings → n8n API → Create API Key)
N8N_API_KEY=

# Proxmox API token (Datacenter → Permissions → API Tokens → Add)
# Format: user@realm!tokenname (e.g. root@pam!homepage)
PROXMOX_TOKEN_ID=root@pam!homepage
PROXMOX_TOKEN_SECRET=
