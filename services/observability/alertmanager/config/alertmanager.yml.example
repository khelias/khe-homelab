# Alertmanager — fan-out for Loki ruler alerts.
#
# Copy to alertmanager.yml (gitignored), fill in the two values below.
# The bot token and chat ID are reused from Uptime Kuma's Telegram
# notification config — grab them from the Uptime Kuma web UI under
# Settings → Notifications.
global:
  resolve_timeout: 5m

# Single route, single receiver for now. Once we have multiple alert
# severities we'll add child routes (e.g. critical → instant, warning →
# digest every 4h).
route:
  receiver: telegram
  group_by: ['alertname', 'container_name']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

receivers:
  - name: telegram
    telegram_configs:
      - bot_token: REPLACE_WITH_TELEGRAM_BOT_TOKEN
        chat_id: -1234567890  # replace with the real chat ID (integer)
        parse_mode: HTML
        send_resolved: true
        message: |
          <b>{{ .Status | toUpper }}</b> {{ .CommonLabels.alertname }}
          {{ range .Alerts }}
          <b>Container:</b> {{ .Labels.container_name }}
          <b>Severity:</b> {{ .Labels.severity }}
          <b>Summary:</b> {{ .Annotations.summary }}
          {{ end }}

inhibit_rules: []
