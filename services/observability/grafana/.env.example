# Grafana admin login. Pick a strong password — Grafana is the door to
# every container's log history.
GRAFANA_ADMIN_PASSWORD=changeme

# Public hostname Grafana renders in absolute URLs (links, redirects).
# LAN-only for v1; e.g. grafana.khe.ee once NPM + AdGuard rewrite is in.
GRAFANA_DOMAIN=grafana.khe.ee
