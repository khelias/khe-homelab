NEXTCLOUD_DOMAIN=cloud.khe.ee
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=generate-a-strong-password
# PostgreSQL superuser password (used only internally by the DB container)
POSTGRES_PASSWORD=generate-a-strong-password
# Nextcloud app DB user password (this user has no CREATEROLE privilege)
NEXTCLOUD_DB_PASSWORD=generate-a-strong-password
DATA_PATH=/srv/data/nextcloud
