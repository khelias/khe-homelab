# Copy to .env on VM and fill in real values. Never commit .env.
#
# At least one provider key must be set. Frontend lets players choose
# per game; DEFAULT_PROVIDER is used when the client does not specify.

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional overrides
# DEFAULT_PROVIDER=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.5-flash
