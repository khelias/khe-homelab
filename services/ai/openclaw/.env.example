# OpenClaw configuration happens via interactive onboarding:
#   docker compose run --rm openclaw onboard
#
# This sets up:
# - AI provider API keys (Anthropic/OpenAI/Ollama)
# - Chat platform connections (Telegram/WhatsApp/Signal)
# - Gateway token for UI access
#
# Ollama integration: openclaw connects to ollama:11434
# via the shared ai-internal Docker network.

# Passthrough env vars referenced by docker-compose.yml — leave empty if not
# using the feature, populate in real .env when enabling.
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
