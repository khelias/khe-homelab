{
  "storageTemplate": {
    "enabled": true,
    "template": "{{y}}/{{y}}-{{MM}}-{{dd}}/{{filename}}"
  },
  "ffmpeg": {
    "accel": "qsv",
    "accelDecode": true,
    "preferredHwDevice": "auto",
    "transcode": "optimal",
    "targetVideoCodec": "h264",
    "crf": 23,
    "preset": "fast"
  },
  "machineLearning": {
    "clip": {
      "enabled": true
    },
    "facialRecognition": {
      "enabled": true
    }
  }
}
