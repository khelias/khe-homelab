# Environment and secrets
.env
*.env
!.env.example

# Runtime data
data/
volumes/
logs/

# AdGuard live config — rewritten by the container at runtime + holds admin creds.
# Canonical baseline lives in AdGuardHome.template.yaml; copy to AdGuardHome.yaml on first deploy.
services/core/adguard/config/AdGuardHome.yaml

# Homepage auto-creates this sample file; we don't use Kubernetes.
services/core/homepage/config/kubernetes.yaml

# Private notes — current security gaps, threat model, anything that would tip off
# an attacker while still unfixed. Public ROADMAP.md covers direction only.
.private/

# OS files
.DS_Store
Thumbs.db

# Backup files (can be large)
backups/*.tar.gz
backups/*.sql

# Editor
.vscode/
.idea/
*.swp
*.swo

# Proxmox exports
*.vma
*.vma.zst
