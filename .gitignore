# Environment and secrets
.env
.env.*
*.env
!.env.example
!.env.heartbeat.example

# Runtime data
data/
volumes/
logs/
.deploy/

# AdGuard live config — rewritten by the container at runtime + holds admin creds.
# Canonical baseline lives in AdGuardHome.template.yaml; copy to AdGuardHome.yaml on first deploy.
services/core/adguard/config/AdGuardHome.yaml
# Timestamped delta-patch backups (AdGuardHome.yaml.bak*); left untracked on the
# VM these blocked deploy.yml's git pull --ff-only on 2026-05-13.
services/core/adguard/config/AdGuardHome.yaml.bak*

# Alertmanager live config — contains the Telegram bot token.
# Baseline lives in alertmanager.yml.example; copy on first deploy.
services/observability/alertmanager/config/alertmanager.yml

# Homepage auto-creates this sample file; we don't use Kubernetes.
services/core/homepage/config/kubernetes.yaml

# Private notes — current security gaps, threat model, anything that would tip off
# an attacker while still unfixed. Public ROADMAP.md covers direction only.
.private/

# OS files
.DS_Store
Thumbs.db

# Backup files (can be large)
backups/*.tar.gz
backups/*.sql

# Editor
.vscode/
.idea/
*.swp
*.swo

# Proxmox exports
*.vma
*.vma.zst
