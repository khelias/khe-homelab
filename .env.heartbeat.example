# Backup heartbeat URLs — point at Uptime Kuma "Push" monitors so a
# missed ping fires the existing Telegram alert. Leave a value blank
# to disable heartbeating for that script.
#
# Setup:
#   1. In Uptime Kuma, create two "Push" monitors:
#        backup-local    — heartbeat interval 28h, retries 1
#        backup-offsite  — heartbeat interval 28h, retries 1
#      (28h covers the 24h cron cadence + 4h slack for slow runs.)
#   2. Each monitor's settings page shows a Push URL like
#        https://uptime-kuma.lan/api/push/abc123
#      Copy it into the matching variable below.
#   3. Save as ~/homelab/.env.heartbeat (mode 0600).
#
# scripts/backup.sh and scripts/offsite-backup.sh source this file
# automatically and ping on exit (status=up on success, status=down on
# any non-zero exit).

HEARTBEAT_URL_BACKUP=
HEARTBEAT_URL_OFFSITE=
