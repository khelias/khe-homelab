{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor"
  ],
  "labels": ["dependencies"],
  "timezone": "Europe/Tallinn",
  "schedule": ["every weekend"],
  "pinDigests": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge all Docker patch and minor updates except critical infrastructure",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["patch", "minor"],
      "excludePackageNames": [
        "adguard/adguardhome",
        "jc21/nginx-proxy-manager",
        "cloudflare/cloudflared",
        "vaultwarden/server",
        "nextcloud",
        "ghcr.io/paperless-ngx/paperless-ngx",
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/immich-app/postgres",
        "postgres",
        "docker.io/valkey/valkey",
        "redis",
        "tecnativa/docker-socket-proxy"
      ],
      "automerge": true
    },
    {
      "description": "Group critical infrastructure minor/major updates for manual review",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": [
        "adguard/adguardhome",
        "jc21/nginx-proxy-manager",
        "cloudflare/cloudflared",
        "vaultwarden/server",
        "nextcloud",
        "ghcr.io/paperless-ngx/paperless-ngx",
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/immich-app/postgres",
        "postgres",
        "docker.io/valkey/valkey",
        "redis",
        "tecnativa/docker-socket-proxy"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "groupName": "critical infrastructure",
      "groupSlug": "critical-updates"
    },
    {
      "description": "Major updates need manual review",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "breaking"]
    },
    {
      "description": "Group adventure-proxy updates (Dockerfile + npm) into one PR",
      "matchFileNames": ["services/apps/games/adventure-proxy/**"],
      "groupName": "adventure-proxy",
      "groupSlug": "adventure-proxy"
    }
  ]
}
